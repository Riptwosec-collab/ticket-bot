# === API Keys (สำคัญ) ===
CAPSOLVER_API_KEY=ใส่_key_capsolver_ที่นี่
# TWOCAPTCHA_API_KEY=optional

# === Proxies (Residential Thailand แนะนำมาก) ===
PROXIES=http://user:pass@th-proxy1:port,http://user:pass@th-proxy2:port

# === บัญชี (หลายบัญชี) ===
ACCOUNTS=[{"email":"your1@gmail.com","pass":"pass123"},{"email":"your2@gmail.com","pass":"pass456"}]

# === การตั้งค่าหลัก ===
EVENT_URL=https://www.thaiticketmajor.com/ใส่ลิงก์คอนเสิร์ต
TARGET_ZONE=VIP
PLATFORM=TTM                    # TTM หรือ TICKETMELON

# === ตัวเลือกขั้นสูง ===
HEADLESS=false                  # true = ซ่อนเบราว์เซอร์, false = แสดง (แนะนำ false)
ENABLE_SOUND=true
ENABLE_NOTIFICATION=true
SESSION_PERSIST=true            # บันทึก session (cookies)
